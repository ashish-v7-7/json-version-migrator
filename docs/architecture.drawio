<mxfile host="app.diagrams.net" agent="json-version-migrator" version="24.0.0">
  <diagram id="arch" name="System Overview">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ════════════════════════════════════════ -->
        <!-- TITLE -->
        <!-- ════════════════════════════════════════ -->
        <mxCell id="title" value="&lt;b&gt;JSON Version Migrator — System Architecture&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#999&quot;&gt;Read Path (green) &amp; Write Path (orange) &amp; Startup (blue)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;" vertex="1" parent="1">
